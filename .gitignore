# ===== Root-level .gitignore for INACORTS =====
# This covers anything that might appear at the repo root or
# patterns not already handled by backend/ and frontend/ .gitignore files.

# Environment files with secrets
.env
.env.local
.env.*.local

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
venv/
.venv/
env/

# Node
node_modules/

# Build artifacts
dist/
build/
*.db
*.sqlite
*.sqlite3

# Database directory — keep the folder, ignore db files
database/*.db
database/*.sqlite
database/*.sqlite3
database/backups/*.db
database/backups/*.sqlite
database/backups/*.sqlite3
!database/.gitkeep
!database/backups/.gitkeep

# Logs — ignore log files but keep directory structure
logs/
backend/logs/
!backend/logs/.gitkeep
!backend/logs/backups/
backend/logs/backups/*
!backend/logs/backups/.gitkeep
*.log

# Coverage & testing
.coverage
htmlcov/
.pytest_cache/

# Misc
*.bak
*.tmp
*.temp
